{
  "database": {
    "rules": "database.rules.json"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "**/*.@(js|css|html)",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ],
    "rewrites": [
      { "source": "/curriculo", "destination": "/curriculo.html" },
      { "source": "/privacidade", "destination": "/privacidade.html" },
      { "source": "/termos", "destination": "/termos.html" },
      { "source": "/suporte", "destination": "/suporte.html" },
      { "source": "/exclusao-conta", "destination": "/exclusao-conta.html" },
      { "source": "/legal", "destination": "/legal.html" }
    ]
  }
}
